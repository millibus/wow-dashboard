# Blizzard API OAuth credentials.
# Create an app at https://develop.battle.net/access/clients to get these.
# Used by both api/server.js (live VPS proxy) and scripts/build-snapshot.js
# (hourly GitHub Actions snapshot — set as repo secrets there too).
BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=

# Express server port (live API on VPS). Optional; defaults to 3002.
PORT=3002
